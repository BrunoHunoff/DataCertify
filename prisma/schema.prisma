generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ENGINEER
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  PAUSED
}

enum CertStatus {
  VALID
  PENDING
  EXPIRED
  IN_PROGRESS
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      Role     @default(ENGINEER)
  name      String
  createdAt DateTime @default(now())

  metricEntries MetricEntry[]
}

model Project {
  id        String        @id @default(uuid())
  name      String
  location  String?
  status    ProjectStatus @default(IN_PROGRESS)
  imageUrl  String?
  createdAt DateTime      @default(now())

  certifications ProjectCertification[]
  metrics        Metric[]
  files          File[]
}

model Certification {
  id          String     @id @default(uuid())
  name        String
  level       String?
  description String?
  issuedAt    DateTime?
  expiresAt   DateTime?
  status      CertStatus @default(PENDING)
  createdAt   DateTime   @default(now())

  projects ProjectCertification[]
  metrics  Metric[]
}

model ProjectCertification {
  id              String        @id @default(uuid())
  projectId       String
  certificationId String
  createdAt       DateTime      @default(now())

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
}

model Metric {
  id              String    @id @default(uuid())
  name            String
  goal            Float
  unit            String
  projectId       String
  certificationId String?
  createdAt       DateTime  @default(now())

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  certification Certification? @relation(fields: [certificationId], references: [id])
  entries       MetricEntry[]
}

model MetricEntry {
  id         String   @id @default(uuid())
  quantity   Float
  date       DateTime
  metricId   String
  loggedById String
  fileUrl    String?
  fileName   String?
  fileType   String?
  createdAt  DateTime @default(now())

  metric   Metric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  loggedBy User   @relation(fields: [loggedById], references: [id])
}

model File {
  id         String   @id @default(uuid())
  fileName   String
  fileUrl    String
  fileType   String
  uploadedAt DateTime @default(now())
  projectId  String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
